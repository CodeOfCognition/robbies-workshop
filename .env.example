# Auth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET=
ALLOWED_GITHUB_ID=CodeOfCognition

# AI (Vercel AI SDK uses this env var name)
GOOGLE_GENERATIVE_AI_API_KEY=

# AI Backend (AWS App Runner) — server-side, used by suggest-preset proxy
BACKEND_URL=
WORKSHOP_BACKEND_API_KEY=


# AI Backend — client-side, used by Transcriber for direct uploads
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_WORKSHOP_BACKEND_API_KEY=

# Supabase (used by /api/tones/* routes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
